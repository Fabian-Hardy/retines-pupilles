# ============================================================
# .gitignore — Rétines & Pupilles
# Python + Node + Docker + données sensibles

# --- Environnement (JAMAIS committer) ---
.env
.env.local
.env.*.local
.env.prod
.env.staging
# Garder l'exemple
!.env.example
# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.pyo
# Virtualenv
.venv/
venv/
ENV/
env.bak/
venv.bak/
# Type checkers & linters
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json
.pytype/
# Tests
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
*.py,cover
# Alembic (généré)
# Ne pas ignorer les fichiers de migration — ils sont versionnés
# --- Node / Frontend ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn-integrity
# Build Vite / React
dist-ssr/
.vite/
*.local
# TypeScript
*.tsbuildinfo
# --- Docker / Infrastructure ---
# Certificats Let's Encrypt — JAMAIS committer
acme.json
traefik/acme.json
# --- Backups ---
backups/
*.sql.gz
*.dump
# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V500
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
# --- IDE ---
.idea/
.vscode/settings.json
*.swp
*.swo
*~
# --- MkDocs ---
site/
# --- Logs ---
*.log
logs/
.local-codex/
.local/agentic-control-plane/
_site/
_reports/*.md
!_reports/.gitkeep
