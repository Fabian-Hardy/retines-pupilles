# ============================================================
# .env.example — Rétines & Pupilles
# Copier en .env et remplir les valeurs avant de démarrer.
# Ne jamais committer .env en Git.
# ============================================================

# --- Application ---
APP_ENV=development
# Clé secrète générale (min. 32 chars) : openssl rand -hex 32
APP_SECRET_KEY=fake_app_secret_key_32_chars_minimum
APP_VERSION=0.1.0
APP_DOMAIN=app.retineetpupille.be

# --- Base de données PostgreSQL ---
DB_HOST=postgresql
DB_PORT=5432
DB_NAME=retines_db
DB_USER=retines
# Mot de passe DB : openssl rand -hex 24
DB_PASS=change_me_db_password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=  # décommenter si Redis sécurisé

# --- JWT ---
# Secret JWT (min. 64 chars) : openssl rand -hex 64
JWT_SECRET_KEY=change_me_jwt_secret_64_chars_min
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Ollama (IA locale — optionnel) ---
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=llama3.2:3b
# Mettre à true pour activer les fonctionnalités IA (résumés, recherche sémantique)
OLLAMA_ENABLED=false

# --- Logging ---
# Niveaux : DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Formats : json | text
LOG_FORMAT=json
