# ============================================================
# backend/.env.example — local backend dev (outside Docker)
# Inside Docker the variables are inherited from the root .env
# Copy to backend/.env and fill in the values.
# ============================================================

# --- Application ---
APP_ENV=development
APP_VERSION=0.1.0
APP_DOMAIN=localhost
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# Master secret key (min. 32 chars) — generate with: openssl rand -hex 32
SECRET_KEY=replace_with_openssl_rand_hex_32_minimum

# --- Database ---
# Either provide DATABASE_URL directly:
# DATABASE_URL=postgresql+asyncpg://retines:password@localhost:5432/retines_db
# ...or provide the DB_* parts and the app will assemble it:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=retines_db
DB_USER=retines
DB_PASS=replace_with_db_password

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
